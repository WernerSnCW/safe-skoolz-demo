{
  "project": {
    "name": "safeskoolz",
    "description": "Multi-role safeguarding and incident reporting platform for schools, compliant with LOPIVI, Convivèxit 2024, and Machista Violence protocols. Powered by Cloudworkz.",
    "branding": "safeskoolz (all lowercase)",
    "targetSchool": "Morna International College, Ibiza",
    "tagline": "A safe space to speak up and seek help."
  },

  "architecture": {
    "type": "pnpm workspace monorepo",
    "language": "TypeScript",
    "structure": {
      "artifacts/api-server": "Express 5 REST API backend",
      "artifacts/safeschool": "React + Vite frontend SPA",
      "lib/db": "Drizzle ORM schema + PostgreSQL connection",
      "lib/api-spec": "OpenAPI specification",
      "lib/api-client-react": "Generated React Query hooks (Orval)",
      "lib/api-zod": "Generated Zod validators",
      "scripts/src/seed.ts": "Database seeding script"
    },
    "stack": {
      "backend": ["Node.js 24", "Express 5", "PostgreSQL", "Drizzle ORM", "Zod", "bcrypt", "jsonwebtoken"],
      "frontend": ["React 19", "Vite", "TailwindCSS", "Framer Motion", "Recharts", "TanStack React Query", "Wouter"],
      "auth": "Custom JWT (bcrypt password hashing, PIN-based for pupils)",
      "build": "esbuild",
      "ai": "OpenAI SDK via Replit AI Integrations (gpt-5-nano)"
    }
  },

  "roles": [
    { "role": "pupil", "loginMethod": "PIN (4-digit)", "capabilities": ["Report incidents (child-friendly form)", "Feelings diary (fully private)", "View behaviour record", "Send messages to safe contacts", "Urgent help button", "View school updates", "Take diagnostic survey", "Training guides"] },
    { "role": "parent", "loginMethod": "Email + password", "capabilities": ["View children's incidents", "Approve/decline teacher consent", "Contact PTA", "View school analytics (anonymised)", "Message school staff", "Take diagnostic survey", "View diagnostic results summary", "View school updates"] },
    { "role": "teacher", "loginMethod": "Email + password", "capabilities": ["Log incidents (professional form)", "View class pupils", "Reset pupil PINs", "Issue behaviour points", "View teacher analytics", "Broadcast school updates (Heads Up)", "Take diagnostic survey", "View diagnostic results summary"] },
    { "role": "head_of_year", "loginMethod": "Email + password", "capabilities": ["All teacher capabilities", "View year group incidents", "Year group oversight"] },
    { "role": "coordinator", "loginMethod": "Email + password", "capabilities": ["Full incident management", "Open/manage protocols", "View all alerts", "Full analytics dashboard", "Manage delegated roles", "Request teacher consent", "Generate/approve PTA annual reports", "Full diagnostic results + priorities/KPIs", "Manage annex templates", "Manage referral bodies", "View audit log"] },
    { "role": "head_teacher", "loginMethod": "Email + password", "capabilities": ["Same as coordinator"] },
    { "role": "senco", "loginMethod": "Email + password", "capabilities": ["SENCO caseload management", "Tracking & progress recording", "Case tasks", "View coordinator dashboard", "View alerts"] },
    { "role": "support_staff", "loginMethod": "Email + password", "capabilities": ["Log incidents", "View assigned incidents", "School updates"] },
    { "role": "pta", "loginMethod": "Email + password", "capabilities": ["PTA Dashboard (anonymised KPIs, mood trends)", "Messaging with coordinator", "Policy acknowledgment/flagging", "Annual report viewing", "Co-design feedback", "Resources library", "Concern submission"] }
  ],

  "features": {
    "incidentManagement": {
      "description": "Comprehensive incident reporting with role-adaptive forms",
      "details": [
        "Child-friendly form for pupils (emoji emotional state, simplified categories)",
        "Professional form for staff (detailed categories, safeguarding checks, person identification)",
        "Three escalation tiers",
        "Emotional state capture (before/after incident)",
        "Location tracking",
        "Unknown person identification support",
        "Per-incident teacher consent workflow (coordinator requests, parent approves/declines)",
        "Redacted view for teachers until parent consent granted",
        "Status workflow: open → under_investigation → resolved/escalated/closed",
        "Reference number generation",
        "Audit-trailed consent decisions"
      ],
      "categories": ["bullying", "cyberbullying", "physical", "verbal", "emotional", "sexual", "neglect", "discrimination", "safeguarding", "coercive_control", "other"]
    },

    "patternDetection": {
      "description": "Automated pattern analysis with 8 detection rules",
      "rules": [
        { "name": "sexual_any", "description": "Any sexual incident triggers immediate red alert" },
        { "name": "same_victim_3_incidents", "description": "Same victim in 3+ incidents" },
        { "name": "same_pair_escalating", "description": "Same victim-perpetrator pair with escalating severity" },
        { "name": "group_targeting", "description": "Multiple perpetrators targeting same victim" },
        { "name": "location_hotspot", "description": "Multiple incidents at same location" },
        { "name": "repeat_perpetrator", "description": "Same perpetrator in multiple incidents" },
        { "name": "emotional_distress_pattern", "description": "Repeated high emotional distress in reports" },
        { "name": "mood_decline", "description": "Sustained low mood (avg ≤2 over 5+ diary entries in 14 days) triggers amber alert to SENCO + coordinators" }
      ],
      "alertLevels": ["red", "amber"],
      "execution": "Cron-scheduled every 60 minutes with deduplication"
    },

    "complianceFrameworks": {
      "supported": ["LOPIVI", "Convivèxit 2024", "Machista Violence"],
      "features": [
        "Protocol management with framework assignment",
        "Annex template library per framework",
        "Mandatory referral engine for critical incidents",
        "Referral body directory management",
        "Delegated roles management"
      ]
    },

    "protocols": {
      "description": "Formal safeguarding protocol management",
      "fields": ["framework", "status", "measures", "referral bodies", "timeline", "JSONB dynamic data"],
      "statuses": ["open", "resolved", "closed"]
    },

    "behaviourTracker": {
      "description": "Points-based behaviour escalation system",
      "levels": 7,
      "features": ["Staff issue points with reasons", "Pupil self-view", "Parent visibility", "Linked to incidents", "Summary view for staff"]
    },

    "pupilDiary": {
      "description": "Fully private wellbeing diary for pupils",
      "privacy": "Only the pupil can see their entries — no parent, teacher, or coordinator access",
      "features": [
        "Daily mood recording (1-5 emoji scale)",
        "Optional text notes",
        "Physical diary aesthetic (leather cover, lined paper, serif fonts)",
        "AI safeguarding scan after each entry (gpt-5-nano)",
        "Flagged entries create pattern_alert with safe message (no diary text exposed)"
      ]
    },

    "messaging": {
      "channels": [
        { "type": "Pupil messages", "description": "Messages to safe contacts + urgent help button" },
        { "type": "Staff inbox", "description": "Internal staff messaging" },
        { "type": "Parent messages", "description": "Parent to school staff communication" },
        { "type": "PTA coordinator channel", "description": "PTA members ↔ coordinator" },
        { "type": "Parent-to-PTA", "description": "Parents can message PTA directly" }
      ]
    },

    "diagnosticSurvey": {
      "description": "Multi-role school climate diagnostic",
      "questionBank": "20 questions across 5 categories",
      "categories": ["Awareness & Prevalence", "Trust & Reporting", "Culture & Wellbeing", "Safeguarding Knowledge", "System Readiness"],
      "respondentGroups": ["pupil", "staff", "parent"],
      "features": [
        "Role-adaptive UI (face emojis for pupils, Likert scale for adults)",
        "Tiered disclosure: coordinators see full results; others see published summary",
        "Published summary includes aggregated scores, participation counts, bar charts by group",
        "Agreed Actions workflow with publish control",
        "Auto-ranked priorities with urgency badges (Critical/High/Moderate/Strength)",
        "KPIs with baseline/target/timeframe per priority",
        "Suggested actions mapped to categories",
        "Strengths, Growth Areas, and Alignment Notes narrative",
        "Demo data seeding (dev-only)"
      ]
    },

    "ptaPortal": {
      "description": "Full PTA member portal with anonymised data",
      "tabs": ["Dashboard", "Coordinator Channel", "Policy", "Annual Report", "Co-Design", "Resources"],
      "features": [
        "Anonymised KPI dashboard",
        "School-wide mood trend chart (12-week rolling, from pupil diary data)",
        "Policy acknowledgment and flagging",
        "Annual report viewing (approved reports only)",
        "Co-design feedback collection",
        "Resources library",
        "Concern submission"
      ],
      "annualReports": {
        "generate": "POST /pta/report/generate (coordinator/head_teacher)",
        "approve": "POST /pta/report/approve (coordinator/head_teacher)",
        "listAll": "GET /pta/report/all (coordinator/head_teacher)",
        "latestApproved": "GET /pta/report/latest (PTA)",
        "reportData": ["totalIncidents", "incidentsByCategory", "protocolsByStatus", "alertsSummary"]
      }
    },

    "sencoCaseload": {
      "description": "SENCO pupil caseload management",
      "features": ["Add/remove pupils", "Progress tracking (4 dimensions)", "Case tasks linked to protocols", "History timeline"]
    },

    "schoolUpdates": {
      "description": "Staff broadcast posts to school community",
      "categories": ["general", "safeguarding", "wellbeing", "curriculum", "event", "policy", "heads_up"],
      "audiences": ["everyone", "pupils", "parents", "staff", "pupils_parents"],
      "specialBehaviour": "'Heads Up' category auto-sets audience to staff with prominent observation guidance banner"
    },

    "educationLearn": {
      "description": "Rights-based education page",
      "content": [
        "Pupil rights (UNCRC, LOPIVI, Convivèxit)",
        "Parent rights and responsibilities",
        "Protocol accordions for all three frameworks",
        "Age-appropriate safety guidance"
      ]
    },

    "newsletter": {
      "description": "Public registration page for organisations interested in safeskoolz",
      "orgTypes": ["school", "authority", "trust", "ngo", "other"]
    },

    "training": {
      "description": "Role-specific feature guides and training materials",
      "includes": ["Pupil quick-start guide", "Parent onboarding", "Staff step-by-step training", "Real-world scenarios"]
    }
  },

  "security": {
    "authentication": {
      "method": "JWT tokens (HS256)",
      "pupilAuth": "PIN-based (4-digit, bcrypt hashed)",
      "staffAuth": "Email + password (bcrypt, 12 rounds)",
      "parentAuth": "Email + password",
      "ptaAuth": "Email + password",
      "sessionTimeout": "90 seconds inactivity for pupils only",
      "rateLimiting": "Auth and newsletter endpoints",
      "lockout": "Failed login attempt tracking with lockout"
    },
    "dataProtection": [
      "Cross-tenant data enforcement (all queries filtered by schoolId)",
      "IDOR prevention on all endpoints",
      "PTA PII middleware strips personal data from PTA responses",
      "Immutable audit logs (PostgreSQL trigger prevents UPDATE/DELETE)",
      "Teacher consent required before sharing incident details",
      "Diary entries never exposed in alerts or logs",
      "Privacy-conscious pupil search",
      "Newsletter subscribe returns 200 regardless (prevents email enumeration)"
    ],
    "cors": "Restricted origins"
  },

  "database": {
    "type": "PostgreSQL",
    "orm": "Drizzle ORM",
    "tables": [
      {
        "name": "schools",
        "columns": ["id (uuid PK)", "name", "legal_entity", "cif", "address", "country", "region", "created_at"]
      },
      {
        "name": "users",
        "columns": ["id (uuid PK)", "school_id (FK)", "role", "first_name", "last_name", "email", "pin_hash", "password_hash", "year_group", "class_name", "avatar_type", "avatar_value", "avatar_image_url", "parent_of (uuid[])", "active", "created_at", "last_login", "failed_login_attempts", "locked_until"]
      },
      {
        "name": "incidents",
        "columns": ["id (uuid PK)", "school_id (FK)", "reference_number", "reporter_id (FK)", "reporter_role", "category", "description", "location", "incident_date", "severity", "emotional_state_before", "emotional_state_after", "involved_persons (jsonb)", "safeguarding_check", "escalation_tier", "status", "teacher_consent_status", "teacher_consent_requested_at", "teacher_consent_responded_at", "teacher_consent_responded_by", "assigned_to (FK)", "resolution_notes", "created_at", "updated_at"]
      },
      {
        "name": "protocols",
        "columns": ["id (uuid PK)", "school_id (FK)", "incident_id (FK)", "framework", "status", "opened_at", "closed_at", "measures (jsonb)", "referral_bodies (jsonb)", "coordinator_notes", "created_at", "updated_at"]
      },
      {
        "name": "pattern_alerts",
        "columns": ["id (uuid PK)", "school_id (FK)", "rule", "alert_level", "target_pupil_id", "perpetrator_pupil_id", "related_incident_ids (uuid[])", "message", "status", "triggered_at", "reviewed_at", "reviewed_by"]
      },
      {
        "name": "audit_log",
        "columns": ["id (uuid PK)", "school_id (FK)", "event_type", "actor_role", "actor_id", "target_type", "target_id", "details (jsonb)", "ip_address", "user_agent", "created_at"],
        "note": "Immutable — PostgreSQL trigger prevents UPDATE/DELETE"
      },
      {
        "name": "messages",
        "columns": ["id (uuid PK)", "school_id (FK)", "sender_id (FK)", "recipient_id (FK)", "body", "is_urgent", "read_at", "created_at"]
      },
      {
        "name": "notifications",
        "columns": ["id (uuid PK)", "school_id (FK)", "user_id (FK)", "type", "title", "body", "link", "read", "created_at"]
      },
      {
        "name": "behaviour_points",
        "columns": ["id (uuid PK)", "school_id (FK)", "pupil_id (FK)", "points", "reason", "category", "incident_id (FK)", "issued_by (FK)", "issued_at", "note"]
      },
      {
        "name": "pupil_diary",
        "columns": ["id (uuid PK)", "school_id (FK)", "pupil_id (FK)", "mood (int, CHECK 1-5)", "note", "created_at"]
      },
      {
        "name": "senco_caseload",
        "columns": ["id (uuid PK)", "school_id (FK)", "pupil_id (FK)", "assigned_by (FK)", "reason", "priority", "status", "notes", "created_at"]
      },
      {
        "name": "senco_tracking",
        "columns": ["id (uuid PK)", "caseload_id (FK)", "pupil_id (FK)", "recorded_by (FK)", "recorded_at", "progress_rating", "feelings_rating", "attitude_to_learning", "attitude_to_others", "notes"]
      },
      {
        "name": "case_tasks",
        "columns": ["id (uuid PK)", "school_id (FK)", "protocol_id (FK)", "title", "assigned_to (FK)", "status", "due_date", "notes", "created_at", "completed_at"]
      },
      {
        "name": "diagnostic_surveys",
        "columns": ["id (uuid PK)", "school_id (FK)", "title", "status", "created_at", "closed_at"]
      },
      {
        "name": "diagnostic_responses",
        "columns": ["id (uuid PK)", "survey_id (FK)", "user_id (FK)", "question_key", "answer (int)", "created_at"]
      },
      {
        "name": "diagnostic_actions",
        "columns": ["id (uuid PK)", "survey_id (FK)", "action", "category", "published_at", "created_at"]
      },
      {
        "name": "pta_messages",
        "columns": ["id (uuid PK)", "school_id (FK)", "sender_id (FK)", "body", "read_at", "created_at"]
      },
      {
        "name": "pta_concerns",
        "columns": ["id (uuid PK)", "school_id (FK)", "submitted_by_id (FK)", "category", "subject", "body", "status", "coordinator_response", "responded_at", "responded_by_id", "created_at"]
      },
      {
        "name": "pta_policy_acknowledgements",
        "columns": ["id (uuid PK)", "school_id (FK)", "user_id (FK)", "policy_version", "action_type", "comment", "created_at"]
      },
      {
        "name": "pta_codesign_responses",
        "columns": ["id (uuid PK)", "school_id (FK)", "submitted_by_id (FK)", "question_key", "response", "created_at"]
      },
      {
        "name": "pta_annual_reports",
        "columns": ["id (uuid PK)", "school_id (FK)", "academic_year", "report_data (jsonb)", "status", "generated_by_id (FK)", "approved_by_id (FK)", "approved_at", "accessed_by_pta_at", "created_at"]
      },
      {
        "name": "teacher_posts",
        "columns": ["id (uuid PK)", "school_id (FK)", "author_id (FK)", "title", "body", "category", "audience", "created_at", "updated_at"]
      },
      {
        "name": "annex_templates",
        "columns": ["id (uuid PK)", "framework", "annex_code", "title", "description", "template_url", "version", "active", "created_at", "updated_at"]
      },
      {
        "name": "delegated_roles",
        "columns": ["id (uuid PK)", "school_id (FK)", "user_id (FK)", "delegated_role", "delegated_by (FK)", "active", "created_at", "revoked_at"]
      },
      {
        "name": "referral_bodies",
        "columns": ["id (uuid PK)", "school_id (FK)", "name", "type", "jurisdiction", "contact_phone", "contact_email", "website", "notes", "active", "created_at"]
      },
      {
        "name": "newsletter_subscribers",
        "columns": ["id (uuid PK)", "email", "organisation_name", "organisation_type", "contact_name", "country", "interests (text[])", "subscribed_at"]
      },
      {
        "name": "interviews",
        "columns": ["id (uuid PK)", "school_id (FK)", "incident_id (FK)", "protocol_id (FK)", "interviewee_id (FK)", "interviewer_id (FK)", "scheduled_at", "status", "notes", "outcome", "created_at"]
      }
    ]
  },

  "apiEndpoints": {
    "authentication": [
      { "method": "POST", "path": "/api/auth/pupil/login", "access": "public", "description": "Pupil PIN login" },
      { "method": "POST", "path": "/api/auth/staff/login", "access": "public", "description": "Staff email+password login" },
      { "method": "POST", "path": "/api/auth/parent/login", "access": "public", "description": "Parent email+password login" },
      { "method": "POST", "path": "/api/auth/demo-login", "access": "public (env-gated)", "description": "Demo quick login" },
      { "method": "GET", "path": "/api/auth/me", "access": "authenticated", "description": "Current user info" },
      { "method": "PATCH", "path": "/api/auth/profile", "access": "authenticated", "description": "Update profile" }
    ],
    "incidents": [
      { "method": "GET", "path": "/api/incidents", "access": "authenticated (role-filtered)", "description": "List incidents" },
      { "method": "POST", "path": "/api/incidents", "access": "authenticated", "description": "Create incident" },
      { "method": "GET", "path": "/api/incidents/:id", "access": "authenticated", "description": "Get incident detail" },
      { "method": "PATCH", "path": "/api/incidents/:id", "access": "coordinator/head_teacher", "description": "Update incident" },
      { "method": "PATCH", "path": "/api/incidents/:id/status", "access": "coordinator/head_teacher", "description": "Update status" },
      { "method": "POST", "path": "/api/incidents/:id/consent-request", "access": "coordinator", "description": "Request teacher consent from parent" },
      { "method": "PATCH", "path": "/api/incidents/:id/consent-respond", "access": "parent", "description": "Approve/decline consent" }
    ],
    "protocols": [
      { "method": "GET", "path": "/api/protocols", "access": "coordinator/head_teacher", "description": "List protocols" },
      { "method": "POST", "path": "/api/protocols", "access": "coordinator/head_teacher", "description": "Create protocol" },
      { "method": "GET", "path": "/api/protocols/:id", "access": "coordinator/head_teacher", "description": "Get protocol detail" },
      { "method": "PATCH", "path": "/api/protocols/:id", "access": "coordinator/head_teacher", "description": "Update protocol" }
    ],
    "alerts": [
      { "method": "GET", "path": "/api/alerts", "access": "coordinator/head_teacher/teacher/head_of_year/senco", "description": "List pattern alerts" },
      { "method": "PATCH", "path": "/api/alerts/:id", "access": "coordinator/head_teacher", "description": "Update alert status" }
    ],
    "dashboard": [
      { "method": "GET", "path": "/api/dashboard/coordinator", "access": "coordinator/head_teacher/senco", "description": "Coordinator dashboard stats" },
      { "method": "GET", "path": "/api/dashboard/analytics", "access": "coordinator/head_teacher/senco", "description": "Full analytics" },
      { "method": "GET", "path": "/api/dashboard/teacher-analytics", "access": "teacher/head_of_year/support_staff", "description": "Teacher analytics" },
      { "method": "GET", "path": "/api/dashboard/parent", "access": "parent", "description": "Parent dashboard" },
      { "method": "GET", "path": "/api/dashboard/child/:id", "access": "coordinator/head_teacher/senco", "description": "Child profile" },
      { "method": "GET", "path": "/api/dashboard/school-overview", "access": "parent", "description": "Anonymised school analytics for parents" }
    ],
    "diagnostics": [
      { "method": "GET", "path": "/api/diagnostics", "access": "authenticated", "description": "List surveys" },
      { "method": "POST", "path": "/api/diagnostics", "access": "coordinator/head_teacher", "description": "Create survey" },
      { "method": "GET", "path": "/api/diagnostics/active", "access": "authenticated", "description": "Get active survey" },
      { "method": "GET", "path": "/api/diagnostics/:id/results", "access": "coordinator/head_teacher", "description": "Full confidential results" },
      { "method": "GET", "path": "/api/diagnostics/:id/summary", "access": "authenticated (closed surveys only)", "description": "Published summary with aggregated scores" },
      { "method": "GET", "path": "/api/diagnostics/:id/actions", "access": "authenticated", "description": "Agreed actions (published only for non-leadership)" },
      { "method": "POST", "path": "/api/diagnostics/:id/respond", "access": "authenticated", "description": "Submit response" },
      { "method": "PATCH", "path": "/api/diagnostics/:id", "access": "coordinator/head_teacher", "description": "Update survey status" },
      { "method": "POST", "path": "/api/diagnostics/:id/actions", "access": "coordinator/head_teacher", "description": "Add action" },
      { "method": "POST", "path": "/api/diagnostics/:id/seed-demo", "access": "coordinator (dev only)", "description": "Seed demo data" }
    ],
    "behaviour": [
      { "method": "GET", "path": "/api/behaviour/levels", "access": "public", "description": "Get escalation levels" },
      { "method": "GET", "path": "/api/behaviour/pupil/:pupilId", "access": "authenticated", "description": "Get pupil behaviour record" },
      { "method": "GET", "path": "/api/behaviour/summary", "access": "staff", "description": "Class/school behaviour summary" },
      { "method": "POST", "path": "/api/behaviour/points", "access": "staff", "description": "Issue behaviour points" },
      { "method": "GET", "path": "/api/behaviour/my-record", "access": "pupil", "description": "Own behaviour record" }
    ],
    "diary": [
      { "method": "GET", "path": "/api/diary/entries", "access": "pupil only", "description": "Get own diary entries" },
      { "method": "POST", "path": "/api/diary/entries", "access": "pupil only", "description": "Create diary entry (triggers AI scan)" },
      { "method": "DELETE", "path": "/api/diary/entries/:id", "access": "pupil only", "description": "Delete own entry" }
    ],
    "messages": [
      { "method": "GET", "path": "/api/messages", "access": "authenticated", "description": "Get messages" },
      { "method": "POST", "path": "/api/messages", "access": "authenticated", "description": "Send message" },
      { "method": "PATCH", "path": "/api/messages/:id/read", "access": "authenticated", "description": "Mark as read" },
      { "method": "GET", "path": "/api/messages/conversations", "access": "authenticated", "description": "Get conversations" },
      { "method": "GET", "path": "/api/messages/child-alerts", "access": "parent", "description": "Child urgent alerts" },
      { "method": "GET", "path": "/api/safe-contacts", "access": "pupil", "description": "Get safe contacts list" },
      { "method": "GET", "path": "/api/parent-contacts", "access": "pupil", "description": "Get parent contacts" }
    ],
    "pta": [
      { "method": "GET", "path": "/api/pta/dashboard", "access": "pta", "description": "PTA dashboard with anonymised KPIs" },
      { "method": "GET", "path": "/api/pta/messages", "access": "pta/coordinator", "description": "PTA-coordinator messages" },
      { "method": "POST", "path": "/api/pta/messages", "access": "pta/coordinator", "description": "Send PTA message" },
      { "method": "GET", "path": "/api/pta/policy", "access": "pta", "description": "Get current policy" },
      { "method": "POST", "path": "/api/pta/policy/acknowledge", "access": "pta", "description": "Acknowledge policy" },
      { "method": "POST", "path": "/api/pta/policy/flag", "access": "pta", "description": "Flag policy concern" },
      { "method": "GET", "path": "/api/pta/concerns", "access": "pta/coordinator", "description": "List concerns" },
      { "method": "POST", "path": "/api/pta/concerns", "access": "pta", "description": "Submit concern" },
